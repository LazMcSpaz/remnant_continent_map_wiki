# Cloudflare Pages headers. Applied to every response at the site root.
# Docs: https://developers.cloudflare.com/pages/configuration/headers/
#
# The Content-Security-Policy below matches the app's DEFAULT sources:
#   - Supabase (REST + realtime websockets): https/wss *.supabase.co
#   - OSM raster tiles: tile.openstreetmap.org
#   - MapLibre GL: creates web workers from blob: URLs and uses WebGL
# If you change VITE_MAP_STYLE_URL / VITE_RASTER_TILE_URL / VITE_SUPABASE_URL to
# other hosts, ADD those hosts to img-src / connect-src below or the browser
# will block them. Keep this in sync with web/.env.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Cross-Origin-Opener-Policy: same-origin
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: blob: https://tile.openstreetmap.org https://*.tile.openstreetmap.org; worker-src 'self' blob:; child-src 'self' blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://tile.openstreetmap.org https://*.tile.openstreetmap.org https://router.project-osrm.org; font-src 'self'; manifest-src 'self'

# Hashed, immutable build assets can be cached hard.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
