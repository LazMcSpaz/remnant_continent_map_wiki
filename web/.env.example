# --- Basemap source ---------------------------------------------------------
# Phase 1 renders a MapLibre basemap. Two ways to supply it:
#
# 1. A full MapLibre vector style URL (preferred — matches the README's
#    OSM vector-tile direction, e.g. a self-hosted PMTiles style or a hosted
#    style endpoint). If set, this wins.
VITE_MAP_STYLE_URL=
#
# 2. If no style URL is given, the app falls back to a built-in raster OSM
#    style so the map renders out of the box for local dev. The raster tile
#    template below can be overridden. (OSM tile usage policy applies — use a
#    proper vector source before shipping.)
VITE_RASTER_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_RASTER_ATTRIBUTION=© OpenStreetMap contributors
#
# 3. Routing (OSRM) — road routes snap to real roads via this server. Defaults
#    to the OSRM public demo. Override with your own instance for production
#    volume; if you change the host, update connect-src in web/public/_headers.
VITE_OSRM_URL=https://router.project-osrm.org
#
# 4. Elevation DEM — Terrarium terrain-RGB tiles (free) sampled in the browser
#    for the rule-based climate model. Override the host in connect-src/img-src
#    of web/public/_headers if you change this.
VITE_DEM_URL=https://elevation-tiles-prod.s3.amazonaws.com/terrarium/{z}/{x}/{y}.png

# --- Supabase backend (authored layer persistence) --------------------------
# Optional. With both unset, the app runs as a viewer with no persistence.
# Project: "Remnant Continent Atlas". Use the publishable key (NOT the secret
# service_role key — that must never ship to the browser).
VITE_SUPABASE_URL=https://butvhkwqgidjmwchuypf.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_WkjeIsfz2R9ARrW3oWSylg_7vKAthEG
