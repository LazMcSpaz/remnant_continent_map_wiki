# --- Basemap source ---------------------------------------------------------
# The basemap is chosen in this precedence order:
#   1. VITE_MAP_STYLE_URL  — a full MapLibre vector style URL (wins if set)
#   2. VITE_MAPTILER_KEY   — builds a MapTiler vector style (clean cartography)
#   3. raster fallback     — CARTO no-labels tiles (works with no config)
#
# 1. A full MapLibre vector style URL (e.g. a self-hosted PMTiles style).
VITE_MAP_STYLE_URL=
#
# 1b. MapTiler vector basemap (recommended for clean, restylable cartography).
#     Get a key at https://www.maptiler.com (free tier). The key ships in the
#     browser bundle, so RESTRICT IT BY DOMAIN in the MapTiler dashboard.
#     On Cloudflare, set VITE_MAPTILER_KEY in the build environment variables.
VITE_MAPTILER_KEY=
# Optional style: dataviz (default) | streets-v2 | landscape | basic-v2 | toner-v2
VITE_MAPTILER_STYLE=dataviz
#
# 2. If neither of the above is set, the app falls back to a built-in raster so
#    the map renders out of the box. The default is CARTO "Voyager — no labels":
#    real roads/highways/rail (the routes tool needs them) but NO place names, so
#    the new-north rotation can't flip text upside-down and real labels don't
#    fight the fiction. {s} cycles a/b/c/d subdomains. Override to plain OSM with:
#      VITE_RASTER_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_RASTER_TILE_URL=https://{s}.basemaps.cartocdn.com/rastertiles/voyager_nolabels/{z}/{x}/{y}.png
VITE_RASTER_ATTRIBUTION=© OpenStreetMap contributors © CARTO
#
# 3. Routing (OSRM) — road routes snap to real roads via this server. Defaults
#    to the OSRM public demo. Override with your own instance for production
#    volume; if you change the host, update connect-src in web/public/_headers.
VITE_OSRM_URL=https://router.project-osrm.org
#
# 4. Elevation DEM — Terrarium terrain-RGB tiles (free) sampled in the browser
#    for the rule-based climate model. Override the host in connect-src/img-src
#    of web/public/_headers if you change this.
VITE_DEM_URL=https://elevation-tiles-prod.s3.amazonaws.com/terrarium/{z}/{x}/{y}.png

# --- Supabase backend (authored layer persistence) --------------------------
# Optional. With both unset, the app runs as a viewer with no persistence.
# Project: "Remnant Continent Atlas". Use the publishable key (NOT the secret
# service_role key — that must never ship to the browser).
VITE_SUPABASE_URL=https://butvhkwqgidjmwchuypf.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_WkjeIsfz2R9ARrW3oWSylg_7vKAthEG
